+            for (int j = 0; j < len; j++) { float u = tmp[i+j], v = tmp[i+j+len]; tmp[i+j] = u+v; tmp[i+j+len] = u-v; }
+    for (int h = 0; h < 8; h++) {
+        outs[h]->d = norm_h;
+        float * seg = &tmp[h*TBQ_K64];
+        float recon[TBQ_K64];
+        int bit_pos = 0;
+        for (int j = 0; j < TBQ_K64*3/8; j++) outs[h]->qs[j] = 0;
+        for (int j = 0; j < TBQ_K64; j++) {
