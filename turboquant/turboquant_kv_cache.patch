+        for (int j = 0; j < TBQ_K64/4; j++) {
+            uint8_t packed = 0;
+            for (int k = 0; k < 4; k++) {
+                uint8_t idx = 3;
+                for (int b = 0; b < 3; b++) { if (seg[j*4+k] < b2[b]) { idx = b; break; } }
+                packed |= (idx & 0x3) << (k*2);
+                recon[j*4+k] = c2[idx];
