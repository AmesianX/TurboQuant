+        const int bp = e * 3;
+        const int by = bp / 8, bo = bp % 8;
+        uint32_t v = (uint32_t)x[ib].qs[by] >> bo;
+        if (bo > 5 && by + 1 < TBQ_K128*3/8) v |= (uint32_t)x[ib].qs[by+1] << (8-bo);
