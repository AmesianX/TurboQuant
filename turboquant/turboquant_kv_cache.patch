+        // MSE query
+#ifdef V_DOT2_F32_F16_AVAILABLE
+        const float2 q_mse = __half22float2(((const half2 *) Q_v)[k_KQ_0/nthreads]);
+#else
+        const float2 q_mse = ((const float2 *) Q_v)[k_KQ_0/nthreads];
+#endif
