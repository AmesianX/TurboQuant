+        -1.7480f, -1.0500f, -0.5006f, 0.0f, 0.5006f, 1.0500f, 1.7480f,
+    };
+
+    float tmp[QK_K];
+    float sum_sq = 0.0f;
+    for (int j = 0; j < QK_K; j++) sum_sq += x[j] * x[j];
+    float norm = sqrtf(sum_sq);
+    y->d = __float2half(norm);
+
+    if (norm < 1e-10f) {
+        for (int j = 0; j < QK_K*3/8; j++) y->qs[j] = 0;
+        return;
+    }
