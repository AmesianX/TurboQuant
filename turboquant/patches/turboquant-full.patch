+        float * blk_data = tmp + blk * 256;
+
+        float blk_sq = 0.0f;
+        for (int j = 0; j < 256; j++) blk_sq += blk_data[j] * blk_data[j];
+        float blk_norm = sqrtf(blk_sq / 256.0f);
