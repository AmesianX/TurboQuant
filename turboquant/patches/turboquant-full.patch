+    const int sign_offset = h * 8; // byte offset for this head's 64-bit signs
+    for (int j = 0; j < TBQ_K64; j++) {
+        const int global_j = h * TBQ_K64 + j;
+        int sign = ((tbq_signs_512_k[global_j >> 3] >> (global_j & 7)) & 1) ? -1 : 1;
