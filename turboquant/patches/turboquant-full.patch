+        0xc5,0x61,0xd8,0x4f,0xa3,0x97,0x1e,0x85,
+    };
+    static constexpr float tbq3_boundaries[7] = {
+        -1.7480f, -1.0500f, -0.5006f, 0.0f, 0.5006f, 1.0500f, 1.7480f,
+    };
+
+    float tmp[512];
