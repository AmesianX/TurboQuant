+    for (int len = 1; len < 256; len *= 2) {
+        int grp = tid/(2*len), pos = tid%(2*len);
+        if (pos < len) { float u=buf[grp*2*len+pos], v=buf[grp*2*len+pos+len]; buf[grp*2*len+pos]=u+v; buf[grp*2*len+pos+len]=u-v; }
+        __syncthreads();
+    }
