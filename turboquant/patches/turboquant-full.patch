+            const int q_idx = blk * (128/nthreads) + k_KQ_0/nthreads;
+#ifdef V_DOT2_F32_F16_AVAILABLE
+            const float2 q = __half22float2(((const half2 *) Q_v)[q_idx]);
+#else
+            const float2 q = ((const float2 *) Q_v)[q_idx];
+#endif
+
+            sum += q.x * cent0 + q.y * cent1;
+        }
+        total += norm * sum;
+    }
+
+    return total;
+}
