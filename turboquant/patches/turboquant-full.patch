+        const int byte_idx1 = ((elem+1) % QK_K) / 4;
+        const float cent0 = c2[(K[ib].qs[byte_idx0] >> (((elem % QK_K) % 4) * 2)) & 0x3];
+        const float cent1 = c2[(K[ib].qs[byte_idx1] >> ((((elem+1) % QK_K) % 4) * 2)) & 0x3];
