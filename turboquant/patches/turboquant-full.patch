+    }
+    float res_abs = 0.0f;
+    for (int j = 0; j < TBQ_K64; j++) res_abs += fabsf(tmp[j] - recon[j]);
+    out->d_qjl = __float2half((res_abs/TBQ_K64)*norm);
+    for (int j = 0; j < TBQ_K64/8; j++) out->qjl[j] = 0;
+    for (int j = 0; j < TBQ_K64; j++) { if (tmp[j]-recon[j] >= 0.0f) out->qjl[j/8] |= (1<<(j%8)); }
