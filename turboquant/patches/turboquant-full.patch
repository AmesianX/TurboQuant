+// TurboQuant_prod: fused score = MSE_term + QJL_term
+// Q_v = WHT(signs1*q)*scale/D (MSE query, in Q_reg)
+// Q_ds_v = WHT(signs2*q)*sqrt(pi/2)/D (QJL query, in Q_ds -- independent random projection)
