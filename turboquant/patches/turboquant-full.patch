+        const float cent = c3[(qs_word_u >> bit_in_word) & 0x7] * norm;
+        if constexpr (std::is_same_v<T, float>) {
+            ((float *) dst)[l] = cent;
+        }
+#ifdef FP16_AVAILABLE
+        else if constexpr (std::is_same_v<T, half>) {
+            ((half *) dst)[l] = __float2half(cent);
+        }
+#endif
+    }
