+    ggml_half d2;
+    ggml_half d2_qjl;
+    uint8_t qs2[QK_K/4];         // 64 bytes
+    uint8_t qjl2[QK_K/8];        // 32 bytes
+    // Sub-block 3: 64 elements (f16 passthrough — rope values stored directly, no WHT)
+    ggml_half rope[TBQ_K64];     // 128 bytes
+} block_tbqp3_4;
+static_assert(sizeof(block_tbqp3_4) == 4*sizeof(ggml_half) + 2*(QK_K/4 + QK_K/8) + TBQ_K64*sizeof(ggml_half), "wrong tbqp3_4 block size/padding");
