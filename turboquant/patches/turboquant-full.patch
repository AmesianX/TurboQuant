 runs:
   using: "composite"
   steps:
-    - name: Determine tag name
+    - name: Determine version
       id: tag
       shell: bash
       run: |
-        BUILD_NUMBER="$(git rev-list --count HEAD)"
-        SHORT_HASH="$(git rev-parse --short=7 HEAD)"
-        if [[ "${{ env.BRANCH_NAME }}" == "master" ]]; then
-          echo "name=b${BUILD_NUMBER}" >> $GITHUB_OUTPUT
-        else
-          SAFE_NAME=$(echo "${{ env.BRANCH_NAME }}" | tr '/' '-')
-          echo "name=${SAFE_NAME}-b${BUILD_NUMBER}-${SHORT_HASH}" >> $GITHUB_OUTPUT
-        fi
+        # Use the most recent v*.*.* tag as the version used in artifact filenames.
+        # This matches the existing release scheme (v1.5.3, v1.5.2, ...) where releases
+        # are created manually and this workflow only attaches binaries to them.
+        TBQ_VERSION="$(git describe --tags --match 'v*' --abbrev=0 2>/dev/null || echo 'v0.0.0')"
+        echo "name=${TBQ_VERSION}" >> $GITHUB_OUTPUT
