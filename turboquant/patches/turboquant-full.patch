+        #pragma unroll
+        for (int k_KQ_0 = 0; k_KQ_0 < 128; k_KQ_0 += nthreads) {
+            const int k = k_KQ_0 + (nthreads == WARP_SIZE ? threadIdx.x : threadIdx.x % nthreads);
