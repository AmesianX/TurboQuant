+    int bit_pos = 0;
+    for (int j = 0; j < QK_K*3/8; j++) y->qs[j] = 0;
+    for (int j = 0; j < QK_K; j++) {
+        uint8_t idx = 7;
+        for (int b = 0; b < 7; b++) { if (tmp[j] < tbq3_boundaries[b]) { idx = b; break; } }
