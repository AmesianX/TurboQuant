+        const int bp = e * 3;
+        const int by = bp >> 3;
+        int start_byte = by & ~1;
+        if (start_byte > (int)(TBQ_K128*3/8) - 4) start_byte = (int)(TBQ_K128*3/8) - 4; // qs is 48 bytes
