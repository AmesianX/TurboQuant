+    for (int j = 0; j < TBQ_K128; j++) {
+        uint8_t idx = 7;
+        for (int b = 0; b < 7; b++) { if (tmp[j] < b3[b]) { idx = b; break; } }
+        int byte_idx = bit_pos / 8, bit_off = bit_pos % 8;
