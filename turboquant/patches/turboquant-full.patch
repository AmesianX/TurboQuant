+                                           const idx_t * __restrict__ src1,
+                                           block_type * __restrict__ dst,
+                                           const int64_t ne_total,
+                                           const int64_t ne10,
+                                           const int64_t ne11,
+                                           const int64_t ne12,
+                                           const int64_t ne13,
+                                           const int64_t s01,
+                                           const int64_t s02,
+                                           const int64_t s03,
+                                           const int64_t s10,
+                                           const int64_t s11,
+                                           const int64_t s12,
+                                           const int64_t s1,
+                                           const int64_t s2,
+                                           const int64_t s3,
