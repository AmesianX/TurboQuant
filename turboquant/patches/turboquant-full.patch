-name: "Determine tag name"
-description: "Determine the tag name to use for a release"
+name: "Determine TurboQuant version"
+description: "Return the latest v*.*.* tag (e.g. v1.5.3) used for artifact naming"
 outputs:
   name:
-    description: "The name of the tag"
+    description: "The version string (e.g. v1.5.3)"
