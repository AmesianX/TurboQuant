+    const int sub = blockIdx.y;
+    const int tid = threadIdx.x;
+
+    static constexpr uint8_t signs1[32] = {
+        0xa7,0x3b,0x91,0xf4,0x6d,0xc2,0x58,0x0e,0xb3,0x7f,0x24,0xd6,0x89,0x45,0xea,0x1c,
