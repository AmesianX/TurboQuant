+    float tmp[512];
+    float sum_sq = 0.0f;
+    for (int h = 0; h < 8; h++)
+        for (int j = 0; j < TBQ_K64; j++) { float v = heads[h][j]; tmp[h*TBQ_K64+j] = v; sum_sq += v*v; }
+    float norm = sqrtf(sum_sq);
+    ggml_half norm_h = __float2half(norm);
