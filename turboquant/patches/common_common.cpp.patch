diff --git a/common/common.cpp b/common/common.cpp
index a9bd49419..e525b0492 100644
--- a/common/common.cpp
+++ b/common/common.cpp
@@ -1225,6 +1225,143 @@ common_init_result::common_init_result(common_params & params) :
         cparams.n_samplers = pimpl->samplers_seq_config.size();
     }
 
+    // TurboQuant auto-mapping: resolve _0 placeholder to correct _N based on head_dim
+    // Also enforce K=q8_0 fallback for head_dim=64 (WHT quality insufficient)
+    {
+        // Get KV head dimension from GGUF metadata: {arch}.attention.key_length
+        int32_t head_dim = 0;
+        {
+            char arch[64] = {}, buf[64] = {};
+            llama_model_meta_val_str(model, "general.architecture", arch, sizeof(arch));
+            if (llama_model_meta_val_str(model, (std::string(arch) + ".attention.key_length").c_str(), buf, sizeof(buf)) > 0) {
+                head_dim = std::atoi(buf);
+            }
+        }
+
+        // Helper: check if a type is any TBQ/TBQP variant
+        auto is_tbq_type = [](ggml_type t) -> bool {
+            return t == GGML_TYPE_TBQ3_0  || t == GGML_TYPE_TBQ4_0
+                || t == GGML_TYPE_TBQP3_0 || t == GGML_TYPE_TBQP4_0
+                || t == GGML_TYPE_TBQ3_1  || t == GGML_TYPE_TBQ4_1
+                || t == GGML_TYPE_TBQP3_1 || t == GGML_TYPE_TBQP4_1
+                || t == GGML_TYPE_TBQ3_2  || t == GGML_TYPE_TBQ4_2
+                || t == GGML_TYPE_TBQP3_2 || t == GGML_TYPE_TBQP4_2
+                || t == GGML_TYPE_TBQ3_3  || t == GGML_TYPE_TBQ4_3
+                || t == GGML_TYPE_TBQP3_3 || t == GGML_TYPE_TBQP4_3;
+        };
+        auto is_tbqp_type = [](ggml_type t) -> bool {
+            return t == GGML_TYPE_TBQP3_0 || t == GGML_TYPE_TBQP4_0
+                || t == GGML_TYPE_TBQP3_1 || t == GGML_TYPE_TBQP4_1
+                || t == GGML_TYPE_TBQP3_2 || t == GGML_TYPE_TBQP4_2
+                || t == GGML_TYPE_TBQP3_3 || t == GGML_TYPE_TBQP4_3;
+        };
+
+        // Validation 1: V cache must not use TBQP (QJL) — no QJL dequantize for V
+        if (is_tbqp_type(cparams.type_v)) {
+            const char * orig = ggml_type_name(cparams.type_v);
+            // Downgrade tbqp → tbq (strip QJL, keep bit-width)
+                 if (cparams.type_v == GGML_TYPE_TBQP3_0) cparams.type_v = GGML_TYPE_TBQ3_0;
+            else if (cparams.type_v == GGML_TYPE_TBQP4_0) cparams.type_v = GGML_TYPE_TBQ4_0;
+            else if (cparams.type_v == GGML_TYPE_TBQP3_1) cparams.type_v = GGML_TYPE_TBQ3_1;
+            else if (cparams.type_v == GGML_TYPE_TBQP4_1) cparams.type_v = GGML_TYPE_TBQ4_1;
+            else if (cparams.type_v == GGML_TYPE_TBQP3_2) cparams.type_v = GGML_TYPE_TBQ3_2;
+            else if (cparams.type_v == GGML_TYPE_TBQP4_2) cparams.type_v = GGML_TYPE_TBQ4_2;
+            else if (cparams.type_v == GGML_TYPE_TBQP3_3) cparams.type_v = GGML_TYPE_TBQ3_3;
+            else if (cparams.type_v == GGML_TYPE_TBQP4_3) cparams.type_v = GGML_TYPE_TBQ4_3;
+            LOG_WRN("%s: TBQP (QJL) not supported for V cache, downgraded %s → %s\n",
+                    __func__, orig, ggml_type_name(cparams.type_v));
+        }
+
+        // Validation 2: _3 (cross-head) types → strip to _0 (will be re-mapped below)
+        auto strip_cross_head = [](ggml_type t) -> ggml_type {
+            if (t == GGML_TYPE_TBQ3_3)  return GGML_TYPE_TBQ3_0;
+            if (t == GGML_TYPE_TBQ4_3)  return GGML_TYPE_TBQ4_0;
+            if (t == GGML_TYPE_TBQP3_3) return GGML_TYPE_TBQP3_0;
+            if (t == GGML_TYPE_TBQP4_3) return GGML_TYPE_TBQP4_0;
+            return t;
+        };
+        if (cparams.type_k != strip_cross_head(cparams.type_k)) {
+            LOG_WRN("%s: cross-head _3 types are deprecated, auto-mapping to standard type\n", __func__);
+            cparams.type_k = strip_cross_head(cparams.type_k);
+        }
+        if (cparams.type_v != strip_cross_head(cparams.type_v)) {
+            LOG_WRN("%s: cross-head _3 types are deprecated, auto-mapping to standard type\n", __func__);
+            cparams.type_v = strip_cross_head(cparams.type_v);
+        }
+
+        // Auto-map _0 types to correct _N based on head_dim
+        auto tbq_resolve = [&](ggml_type type, bool is_key) -> ggml_type {
+            struct tbq_map { ggml_type from; ggml_type to_256; ggml_type to_128; ggml_type to_64; };
+            static const tbq_map maps[] = {
+                { GGML_TYPE_TBQ3_0,  GGML_TYPE_TBQ3_0,  GGML_TYPE_TBQ3_1,  GGML_TYPE_TBQ3_2  },
+                { GGML_TYPE_TBQ4_0,  GGML_TYPE_TBQ4_0,  GGML_TYPE_TBQ4_1,  GGML_TYPE_TBQ4_2  },
+                { GGML_TYPE_TBQP3_0, GGML_TYPE_TBQP3_0, GGML_TYPE_TBQP3_1, GGML_TYPE_TBQP3_2 },
+                { GGML_TYPE_TBQP4_0, GGML_TYPE_TBQP4_0, GGML_TYPE_TBQP4_1, GGML_TYPE_TBQP4_2 },
+            };
+
+            // Also catch _1/_2 types that don't match head_dim (user specified directly)
+            auto is_wrong_suffix = [&](ggml_type t) -> bool {
+                bool is_1 = (t == GGML_TYPE_TBQ3_1 || t == GGML_TYPE_TBQ4_1 || t == GGML_TYPE_TBQP3_1 || t == GGML_TYPE_TBQP4_1);
+                bool is_2 = (t == GGML_TYPE_TBQ3_2 || t == GGML_TYPE_TBQ4_2 || t == GGML_TYPE_TBQP3_2 || t == GGML_TYPE_TBQP4_2);
+                if (is_1 && head_dim != 128) return true;
+                if (is_2 && head_dim != 64)  return true;
+                return false;
+            };
+            if (is_wrong_suffix(type)) {
+                const ggml_type fallback = is_key ? GGML_TYPE_Q8_0 : GGML_TYPE_F16;
+                LOG_WRN("%s: %s does not match head_dim=%d, falling back to %s\n",
+                        __func__, ggml_type_name(type), head_dim, ggml_type_name(fallback));
+                return fallback;
+            }
+
+            for (const auto & m : maps) {
+                if (type == m.from) {
+                    if (head_dim == 256) {
+                        if (m.to_256 != type) {
+                            LOG_INF("%s: TurboQuant auto-mapped %s → %s (head_dim=%d)\n",
+                                    __func__, ggml_type_name(type), ggml_type_name(m.to_256), head_dim);
+                        }
+                        return m.to_256;
+                    } else if (head_dim == 128) {
+                        LOG_INF("%s: TurboQuant auto-mapped %s → %s (head_dim=%d)\n",
+                                __func__, ggml_type_name(type), ggml_type_name(m.to_128), head_dim);
+                        return m.to_128;
+                    } else if (head_dim == 64) {
+                        if (is_key) {
+                            LOG_WRN("\n");
+                            LOG_WRN("╔══════════════════════════════════════════════════════════════╗\n");
+                            LOG_WRN("║  TurboQuant: head_dim=%d detected — K cache forced to q8_0  ║\n", head_dim);
+                            LOG_WRN("║  WHT quantization degrades attention accuracy at dim<128.   ║\n");
+                            LOG_WRN("║  V cache uses %s (WHT is OK for values)                 ║\n", ggml_type_name(m.to_64));
+                            LOG_WRN("╚══════════════════════════════════════════════════════════════╝\n");
+                            LOG_WRN("\n");
+                            return GGML_TYPE_Q8_0;
+                        }
+                        LOG_INF("%s: TurboQuant auto-mapped %s → %s (head_dim=%d)\n",
+                                __func__, ggml_type_name(type), ggml_type_name(m.to_64), head_dim);
+                        return m.to_64;
+                    } else {
+                        LOG_WRN("%s: unsupported head_dim=%d for TurboQuant, falling back to %s\n",
+                                __func__, head_dim, is_key ? "q8_0" : "f16");
+                        return is_key ? GGML_TYPE_Q8_0 : GGML_TYPE_F16;
+                    }
+                }
+            }
+            return type; // not a _0 TBQ type, pass through
+        };
+
+        if (is_tbq_type(cparams.type_k) || is_tbq_type(cparams.type_v)) {
+            if (head_dim <= 0) {
+                LOG_WRN("%s: could not determine head_dim from model metadata, TurboQuant disabled\n", __func__);
+                if (is_tbq_type(cparams.type_k)) cparams.type_k = GGML_TYPE_Q8_0;
+                if (is_tbq_type(cparams.type_v)) cparams.type_v = GGML_TYPE_F16;
+            } else {
+                cparams.type_k = tbq_resolve(cparams.type_k, true);
+                cparams.type_v = tbq_resolve(cparams.type_v, false);
+            }
+        }
+    }
+
     llama_context * lctx = llama_init_from_model(model, cparams);
     if (lctx == NULL) {
         LOG_ERR("%s: failed to create context with model '%s'\n", __func__, params.model.path.c_str());
