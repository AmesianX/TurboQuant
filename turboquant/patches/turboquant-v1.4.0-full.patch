+        for (int j = 0; j < TBQ_K64; j++) { if (res[j] >= 0.0f) qjl_out[j/8] |= (1<<(j%8)); }
+    };
+
+    quant_sub_qjl(x,       signs_256, qjl_signs_256, &y->d1, &y->d1_qjl, y->qs1, y->qjl1);
+    quant_sub_qjl(x + 256, signs_256, qjl_signs_256, &y->d2, &y->d2_qjl, y->qs2, y->qjl2);
