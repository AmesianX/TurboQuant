+            corr1 = (K->qjl1[(e+1)/8]>>((e+1)%8))&1;
+            use_qjl = true;
+        } else if (elem < 512) {
+            // Sub-block 2: elements [256, 512)
+            const int e = elem - 256;
+            norm = __half2float(K->d2); d_corr = __half2float(K->d2_qjl);
+            cent0 = c2[(K->qs2[e/4]>>((e%4)*2))&0x3];
