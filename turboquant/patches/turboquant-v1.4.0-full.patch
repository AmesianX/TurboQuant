+            for (int j = 0; j < len; j++) { float u = tmp[i+j], v = tmp[i+j+len]; tmp[i+j] = u+v; tmp[i+j+len] = u-v; }
+    // Quantize per 64-element block: 2-bit centroid + direct sign
+    for (int h = 0; h < 8; h++) {
+        outs[h]->d = norm_h;
