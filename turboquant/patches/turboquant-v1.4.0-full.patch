+        *d_out = __float2half(norm);
+        if (norm < 1e-10f) {
+            for (int j = 0; j < TBQ_K64/4; j++) qs_out[j] = 0;
+            for (int j = 0; j < TBQ_K64/8; j++) qjl_out[j] = 0;
