+            for (int j = 0; j < TBQ_K64/8; j++) outs[h]->qjl[j] = 0;
+        }
+        return;
+    }
+    float inv_norm = 1.0f / norm;
+    for (int j = 0; j < 512; j++) { int sign = ((tbq_signs_512[j>>3]>>(j&7))&1)?-1:1; tmp[j] *= inv_norm * sign; }
+    for (int len = 1; len < 512; len *= 2)
