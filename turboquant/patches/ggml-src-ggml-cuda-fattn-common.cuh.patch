+        // qs: 4-bit packed, 2 elements per byte. Each thread reads 1 byte (qs_byte=k).
+        // Load 4 bytes (4 thread-bytes) starting from 2-byte aligned base.
+        // qs is 64 bytes; clamp window start to 60 to keep load in bounds.
+        const int qs_byte = k;
