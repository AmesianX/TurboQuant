+    const bool is_blk1 = (elem < 256);
+    const float norm = __half2float(is_blk1 ? x[ib].d1 : x[ib].d2);
+    const uint8_t * qs = is_blk1 ? x[ib].qs1 : x[ib].qs2;
+    const int e_base = is_blk1 ? elem : (elem - 256);
