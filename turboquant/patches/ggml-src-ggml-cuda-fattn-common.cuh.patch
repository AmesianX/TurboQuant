+        // Use 2-byte aligned 4-byte load (start_byte even). bit_in_word ≤ 15 in normal case,
+        // ≤ 26 in clamped tail case — both fit within 32-bit window (cent1 high bit ≤ 31).
+        const int bp0 = elem * 3;
