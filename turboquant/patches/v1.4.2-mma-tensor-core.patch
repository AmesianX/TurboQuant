+#pragma unroll
+    for (int jc0 = 0; jc0 < cpw; jc0 += KQ_cs) {
+#ifdef FAST_FP16_AVAILABLE
+        __align__(16) half  tmp[nbatch_fa/(np*warp_size)][KQ_cs];
