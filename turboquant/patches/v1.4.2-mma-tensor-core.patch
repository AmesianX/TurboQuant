+            buf[tid] = c3[r&7] * norm;
+        }
+        tbq_iwht_256(buf, tid);
+        out[sub*256+tid] = __float2half(buf[tid]);
+    }
+    if (tid < 64) out[512+tid] = blk->rope[tid];
+}
+
+void tbqp3_v_spatial_f16_cuda(const void * vx, half * y, int64_t k, cudaStream_t stream) {
