++    static constexpr float c2[4] = { -1.5104f,-0.4528f,0.4528f,1.5104f };
++    static constexpr float c3[8] = { -2.1520f,-1.3440f,-0.7560f,-0.2451f,0.2451f,0.7560f,1.3440f,2.1520f };
